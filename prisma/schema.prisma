generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================
// AIMSCS Smart Campus Management System (SCMS)
// AMS + LMS Database Schema — R22 Regulation
// ============================================

// --- CORE: Masters ---
model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique  // CSE, ECE, EEE, MECH, CIVIL, IT, CSE-AIML, CSE-DS, CSE-NT
  hodId       String?  @unique
  building    String?
  floor       String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hod         User?    @relation("DepartmentHOD", fields: [hodId], references: [id])
  programs    Program[]
  subjects    Subject[]
}

model AcademicYear {
  id          String   @id @default(cuid())
  name        String   @unique  // "2025-2026"
  code        String   @unique  // "AY2526"
  startDate   String   // YYYY-MM-DD
  endDate     String   // YYYY-MM-DD
  status      String   @default("upcoming") // upcoming, active, completed
  regulation  String?  // R22, R25
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  semesters   Semester[]
  calendarEvents CalendarEvent[]
}

model Semester {
  id            String   @id @default(cuid())
  academicYearId String
  name          String   // "I Year I Sem", "II Year II Sem"
  code          String   // "I-I", "I-II", "II-I", "II-II", "III-I", "III-II", "IV-I", "IV-II"
  year          Int      @default(1)  // 1, 2, 3, 4
  semester      Int      @default(1)  // 1 or 2
  startDate     String
  endDate       String
  status        String   @default("upcoming") // upcoming, active, completed
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id])
  subjects      Subject[]
  timetableSlots TimetableSlot[]

  @@unique([academicYearId, code])
}

model Subject {
  id            String   @id @default(cuid())
  code          String   @unique  // MA101BS, CS201ES, etc. (JNTU R22 pattern)
  name          String
  departmentId  String
  semesterId    String?
  credits       Int      @default(3)
  lectureHours  Int      @default(3)  // L
  tutorialHours Int      @default(0)  // T
  labHours      Int      @default(0)  // P
  type          String   @default("core") // core, elective, audit, lab, project, open_elective, professional_elective
  category      String?  // BS, ES, PC, PE, OE, HS (JNTU category codes)
  syllabus      String?  // Full syllabus text
  textbooks     String?  // JSON array of textbooks
  referenceBooks String? // JSON array of reference books
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department    Department @relation(fields: [departmentId], references: [id])
  semester      Semester?  @relation(fields: [semesterId], references: [id])
  courses       Course[]
}

// --- CORE: Users & RBAC ---
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  employeeId    String?  @unique
  departmentId  String?
  department    String?
  phone         String?
  avatarUrl     String?
  profileImageUrl String?  // Profile photo URL for face recognition & display
  role          String   @default("student") // super_admin, admin, hod, faculty, lab_assistant, student, parent, visitor, security
  linkedStudentId String?  // For parent role: linked ward student id
  status        String   @default("active")  // active, inactive, suspended
  passwordHash  String   @default("$2a$10$placeholder")
  mfaEnabled    Boolean  @default(false)
  mfaSecret     String?
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  departmentRef      Department?         @relation("DepartmentHOD")
  faceEmbeddings     FaceEmbedding[]
  biometricRecords   BiometricRecord[]
  attendanceRecords  AttendanceRecord[]
  attendanceSessions AttendanceSession[] @relation("SessionCreator")
  courseEnrollments  CourseEnrollment[]
  submissions        Submission[]
  quizAttempts       QuizAttempt[]
  violations         AttendanceViolation[] @relation("Violator")
  reviewedViolations AttendanceViolation[] @relation("Reviewer")
  taughtCourses      Course[]            @relation("CourseInstructor")
  gradedEntries      GradeBook[]         @relation("GradeGrader")
  studentGrades      GradeBook[]         @relation("GradeStudent")
  calendarEvents     CalendarEvent[]
  knuctWallet        KnuctWallet?
  rbacOverride       UserRbacOverride?
  knuctCredentials   KnuctCredential[]
  knuctWalletProvisionRequests KnuctWalletProvisionRequest[]
}

model KnuctWallet {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  did          String?
  privShareEnc Bytes?
  status       String   @default("pending") // pending | active | failed
  lastError    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([did])
}

model KnuctRegistrationRequest {
  id              String   @id @default(cuid())
  did             String   @unique
  email           String
  name            String
  employeeId      String?
  phone           String?
  departmentId    String?
  department      String?
  requestedRole   String   @default("student")
  status          String   @default("pending") // pending | approved | rejected
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  approvedUserId  String?  @unique
  privShareEnc    Bytes?
  walletSource    String   @default("existing") // existing | created
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model KnuctWalletProvisionRequest {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestType     String   // create | reprovision
  status          String   @default("pending") // pending | approved | rejected
  userNote        String?
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([createdAt])
}

model BlockchainAnchor {
  id           String   @id @default(cuid())
  resourceType String   // attendance_session | violation_review | grade_publish
  resourceId   String
  payloadHash  String
  knuctTxRef   String?
  status       String   @default("anchored") // anchored | pending | unavailable | failed
  lastError    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@index([status])
}

model KnuctCredential {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String   // attendance_certificate | grade_transcript | compliance_report
  resourceId    String?
  payloadHash   String
  knuctAssetRef String?
  verifyUrl     String?
  status        String   @default("pending") // pending | issued | failed | unavailable
  lastError     String?
  metadata      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([payloadHash])
}

model FaceEmbedding {
  id           String   @id @default(cuid())
  userId       String
  embedding    String
  model        String   @default("ArcFace")
  qualityScore Float    @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BiometricRecord {
  id         String   @id @default(cuid())
  userId     String
  type       String
  template   String
  deviceId   String?
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- AMS: Attendance Management ---
model TimetableSlot {
  id           String   @id @default(cuid())
  courseId     String
  semesterId   String?
  dayOfWeek    Int      // 0=Sunday, 6=Saturday
  startTime    String   // HH:mm format
  endTime      String   // HH:mm format
  roomNumber   String?
  building     String?
  semester     String?
  academicYear String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course             Course              @relation(fields: [courseId], references: [id])
  semesterRef        Semester?           @relation(fields: [semesterId], references: [id])
  attendanceSessions AttendanceSession[]

  @@index([courseId, dayOfWeek, isActive])
  @@index([semesterId])
  @@index([academicYear])
}

model Geofence {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("circle")
  centerLat   Float?
  centerLng   Float?
  radiusMtrs  Float?
  polygonData String?
  building    String?
  floor       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendanceSessions AttendanceSession[]
}

model AttendanceSession {
  id             String   @id @default(cuid())
  timetableSlotId String?
  courseId       String
  createdBy      String
  geofenceId     String?
  sessionDate    String
  startTime      String
  endTime        String?
  status         String   @default("upcoming")
  captureMethod  String   @default("manual")
  expectedCount  Int      @default(0)
  presentCount   Int      @default(0)
  absentCount    Int      @default(0)
  lateCount      Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  timetableSlot  TimetableSlot?       @relation(fields: [timetableSlotId], references: [id])
  course         Course               @relation(fields: [courseId], references: [id])
  creator        User                 @relation("SessionCreator", fields: [createdBy], references: [id])
  geofence       Geofence?            @relation(fields: [geofenceId], references: [id])
  records        AttendanceRecord[]

  @@index([timetableSlotId, sessionDate, status])
  @@index([courseId, sessionDate, status])
}

model AttendanceRecord {
  id           String   @id @default(cuid())
  sessionId    String
  studentId    String
  status       String   @default("absent")
  markedAt     DateTime?
  captureMethod String  @default("manual")
  confidence   Float?
  gpsLat       Float?
  gpsLng       Float?
  ipAddress    String?
  deviceId     String?
  selfieUrl    String?   // Selfie image URL captured during attendance
  faceVerified Boolean  @default(false)  // Whether face was verified
  geofenceValidated Boolean @default(false)  // Whether GPS was within geofence
  distanceFromCenter Float?  // Distance in meters from geofence center
  remarks      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User              @relation(fields: [studentId], references: [id])
  violation AttendanceViolation?

  @@unique([sessionId, studentId])
}

model AttendanceViolation {
  id           String   @id @default(cuid())
  recordId     String   @unique
  studentId    String
  type         String
  severity     String   @default("medium")
  description  String?
  reviewedBy   String?
  reviewStatus String   @default("pending")
  reviewNotes  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  record    AttendanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  violator  User             @relation("Violator", fields: [studentId], references: [id])
  reviewer  User?            @relation("Reviewer", fields: [reviewedBy], references: [id])
}

// --- LMS: Learning Management System ---
model Program {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  departmentId String
  duration    Int      @default(4)
  type        String   @default("ug")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  courses    Course[]
}

model Course {
  id           String   @id @default(cuid())
  programId    String
  subjectId    String?
  code         String   @unique
  name         String
  credits      Int      @default(3)
  semester     Int      @default(1)
  type         String   @default("core")
  description  String?
  instructorId String?
  syllabus     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  program             Program              @relation(fields: [programId], references: [id])
  subject             Subject?             @relation(fields: [subjectId], references: [id])
  instructor          User?                @relation("CourseInstructor", fields: [instructorId], references: [id])
  enrollments         CourseEnrollment[]
  modules             Module[]
  timetableSlots      TimetableSlot[]
  attendanceSessions  AttendanceSession[]
  assignments         Assignment[]
  quizQuestions       QuizQuestion[]
  quizAttempts        QuizAttempt[]
  gradeBooks          GradeBook[]
}

model CourseEnrollment {
  id          String    @id @default(cuid())
  courseId    String
  studentId   String
  status      String    @default("enrolled")
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  course   Course @relation(fields: [courseId], references: [id])
  student  User   @relation(fields: [studentId], references: [id])

  @@unique([courseId, studentId])
}

model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  orderIndex  Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
}

model Lesson {
  id          String   @id @default(cuid())
  moduleId    String
  title       String
  type        String   @default("video")
  contentUrl  String?
  contentBody String?
  duration    Int?
  orderIndex  Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Assignment {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  type        String   @default("individual")
  maxScore    Float    @default(100)
  dueDate     DateTime
  allowLate   Boolean  @default(true)
  latePenalty Float    @default(0)
  attachments String?
  status      String   @default("published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course      @relation(fields: [courseId], references: [id])
  submissions Submission[]
}

model Submission {
  id           String   @id @default(cuid())
  assignmentId String
  studentId    String
  content      String?
  fileUrls     String?
  score        Float?
  feedback     String?
  status       String   @default("submitted")
  submittedAt  DateTime @default(now())
  gradedAt     DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
}

model QuizQuestion {
  id            String   @id @default(cuid())
  courseId      String
  question      String
  type          String   @default("mcq")
  options       String?
  correctAnswer String?
  points        Float    @default(1)
  difficulty    String   @default("medium")
  explanation   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id])
}

model QuizAttempt {
  id           String    @id @default(cuid())
  studentId    String
  courseId     String
  questions    String
  answers      String
  score        Float     @default(0)
  totalPoints  Float     @default(0)
  percentage   Float     @default(0)
  timeTaken    Int?
  status       String    @default("completed")
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])
}

model GradeBook {
  id          String   @id @default(cuid())
  courseId     String
  studentId    String
  component    String
  componentId  String?
  score        Float
  maxScore     Float
  weightage    Float    @default(0)
  remarks      String?
  gradedBy     String?
  gradedAt     DateTime @default(now())

  course   Course @relation(fields: [courseId], references: [id])
  student  User   @relation("GradeStudent", fields: [studentId], references: [id])
  grader   User?  @relation("GradeGrader", fields: [gradedBy], references: [id])
}

// --- CALENDAR ---
model CalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  type        String   @default("personal") // personal, academic, exam, holiday, event, deadline, class
  startDate   String   // YYYY-MM-DD
  endDate     String?  // YYYY-MM-DD
  startTime   String?  // HH:mm
  endTime     String?  // HH:mm
  location    String?
  color       String?  // hex color
  isAllDay    Boolean  @default(false)
  courseId    String?
  academicYearId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])
}

// --- System: RBAC & Audit ---
model RbacConfig {
  id        String   @id @default("default")
  matrix    Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model SystemConfig {
  id        String   @id @default("default")
  settings  Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model UserRbacOverride {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grant     Json     @default("[]")
  revoke    Json     @default("[]")
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

// --- Centralized Settings Framework ---
model SettingValue {
  id        String   @id @default(cuid())
  key       String
  scope     String   @default("global") // global | organization | department | user
  scopeId   String   @default("")
  value     Json
  version   Int      @default(1)
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, scope, scopeId])
  @@index([key])
  @@index([scope, scopeId])
}

model SettingHistory {
  id        String   @id @default(cuid())
  key       String
  scope     String   @default("global")
  scopeId   String   @default("")
  value     Json
  version   Int
  updatedBy String?
  reason    String?
  createdAt DateTime @default(now())

  @@index([key, scope, scopeId, version])
  @@index([createdAt])
}

model SettingFavorite {
  id        String   @id @default(cuid())
  userId    String
  key       String
  createdAt DateTime @default(now())

  @@unique([userId, key])
  @@index([userId])
}

model SettingRecent {
  id         String   @id @default(cuid())
  userId     String
  key        String
  accessedAt DateTime @default(now())

  @@unique([userId, key])
  @@index([userId, accessedAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  channel   String   @default("in_app")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}
