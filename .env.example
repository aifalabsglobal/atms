# AIMSCS — copy to .env and fill in values

# Required
DATABASE_URL="postgresql://user:pass@host/neondb?sslmode=require&pgbouncer=true&connect_timeout=30"
NEXTAUTH_SECRET="generate-a-32+-char-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Redis rate limiting (Upstash — multi-instance production)
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# Single-instance Docker/self-hosted only (not for multi-instance Vercel)
# ALLOW_IN_MEMORY_RATE_LIMIT="true"

# Optional: Email (Resend — recommended on Vercel)
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="AIMSCS <noreply@yourdomain.ac.in>"

# Optional: Email (SMTP alternative)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="noreply@yourdomain.ac.in"
# SMTP_PASS="app-password"
# SMTP_FROM="AIMSCS <noreply@yourdomain.ac.in>"

# Optional: Face verification (external ArcFace / Rekognition service)
# FACE_VERIFICATION_ENABLED="false"
# FACE_VERIFICATION_API_URL="https://your-face-api/verify"
# FACE_VERIFICATION_API_KEY="xxx"

# Optional: Knuct blockchain — live pilot
KNUCT_ENABLED="true"
KNUCT_BASE_URL="https://webwallet.knuct.com"
KNUCT_WALLET_ON_USER_CREATE="false"
KNUCT_PRIVSHARE_ENC_KEY="change-me-generate-64-char-hex-key-for-production"
KNUCT_MAX_RETRIES="2"
KNUCT_CIRCUIT_BREAKER_THRESHOLD="5"
KNUCT_ANCHOR_ENABLED="true"
KNUCT_PILOT_COHORT_LIMIT="25"
# If vendor provided credentials, uncomment:
# KNUCT_API_KEY=""
# KNUCT_API_SECRET=""
# KNUCT_TENANT_ID=""

# Phase 3: chain publish (requires vendor publish API URL — see docs/KNUCT_Vendor_Questionnaire.md)
# KNUCT_CHAIN_PUBLISH_ENABLED="false"
# KNUCT_CHAIN_PUBLISH_URL="https://webwallet.knuct.com/sapi/publishanchor"

# Phase 2: verifiable credentials (requires vendor mint/verify API URLs)
# KNUCT_CREDENTIALS_ENABLED="false"
# KNUCT_CREDENTIAL_MINT_URL="https://webwallet.knuct.com/sapi/mintcredential"
# KNUCT_CREDENTIAL_VERIFY_URL="https://webwallet.knuct.com/sapi/verifycredential/{assetRef}"
